# ============================================
# A股全量信息检索知识库 — 环境变量配置
# ============================================

# --- API 认证 ---
API_TOKEN=change-me-to-a-strong-random-token

# --- 服务配置 ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- 数据库 (MVP: SQLite, 生产: PostgreSQL) ---
# MVP模式（默认）: SQLite
DB_PATH=./data/astock_kb.db
# 生产模式（取消注释）:
# DATABASE_URL=postgresql://astock:***
# ES_URL=http://elasticsearch:9200
# REDIS_URL=redis://redis:6379/0

# --- 数据采集 ---
# Tushare Pro Token (https://tushare.pro)
TUSHARE_TOKEN=
# 东方财富Cookie（可选，用于反爬绕过）
EASTMONEY_COOKIE=
# 雪球Cookie（可选）
XUEQIU_COOKIE=

# --- LLM (可选，用于情感分析/摘要) ---
# DASHSCOPE_API_KEY=***
# LLM_MODEL=qwen-plus

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=./logs/astock_kb.log
